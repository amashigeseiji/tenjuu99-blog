{
  "site_name": "test",
  "url_base": "http://localhost:8000",
  "src_dir": "src-sample",
  "dist_dir": "dist",
  "distribute_raw": "image,js",
  "helper": "index.js,add.js",
  "editor_enable": true,
  "image_converter": "sharp",
  "packages": "editor,turbolink,breadcrumbs,category",
  "hooks": {
    "afterIndexing": "categoryIndexer.js"
  },
  "frontmatter_templates": [
    {
      "path_prefix": "book/",
      "fields": {
        "title": "",
        "price": "0",
        "author": "",
        "publisher": "",
        "isbn": "",
        "language": "ja",
        "in_stock": "true"
      }
    }
  ],
  "categories": [
    {
      "name": "books",
      "url_prefix": "",
      "path_filter": "book/",
      "template": "category.html",
      "auto_generate": true,
      "max_depth": 3,
      "url_case": "lower",
      "url_separator": "-",
      "per_page": 2
    },
    {
      "name": "articles",
      "url_prefix": "/article-list",
      "path_filter": "article/",
      "template": "category.html",
      "auto_generate": true,
      "max_depth": 3,
      "url_case": "lower",
      "url_separator": "-"
    },
    {
      "name": "art",
      "url_prefix": "",
      "path_filter": "art/",
      "template": "category.html",
      "auto_generate": true,
      "max_depth": 3,
      "url_case": "lower",
      "url_separator": "-"
    },
    {
      "name": "tech",
      "url_prefix": "",
      "path_filter": "tech/",
      "template": "category.html",
      "auto_generate": true,
      "max_depth": 3,
      "url_case": "lower",
      "url_separator": "-"
    }
  ]
}
