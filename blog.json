{
  "site_name": "test",
  "url_base": "http://localhost:8000",
  "src_dir": "src-sample",
  "dist_dir": "dist",
  "distribute_raw": "image,js",
  "helper": "index.js,add.js",
  "editor_enable": true,
  "packages": "editor,turbolink,breadcrumbs,category",
  "hooks": {
    "afterIndexing": "categoryIndexer.js"
  },
  "category": {
    "template": "category.html",
    "auto_generate": true,
    "max_depth": 3,
    "url_case": "lower",
    "url_separator": "-",
    "url_prefix": ""
  }
}
